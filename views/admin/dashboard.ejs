<% layout("/layouts/admin_boilerplate.ejs")%>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Admin Overview</h2>
</div>

<div class="tab-content" id="adminTabsContent">
    
    <!-- Dashboard Stats Tab -->
    <div class="tab-pane fade show active" id="dashboard-tab-pane" role="tabpanel" aria-labelledby="dashboard-tab" tabindex="0">
        <div class="row mb-5">
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-primary h-100">
                    <div class="card-body p-4 text-center">
                        <h5 class="card-title text-primary"><i class="fa-solid fa-users"></i> Total Users</h5>
                        <h2 class="display-5 fw-bold mt-2"><%= totalUsers %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-success h-100">
                    <div class="card-body p-4 text-center">
                        <h5 class="card-title text-success"><i class="fa-solid fa-house"></i> Total Listings</h5>
                        <h2 class="display-5 fw-bold mt-2"><%= totalListings %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm border-warning h-100">
                    <div class="card-body p-4 text-center">
                        <h5 class="card-title text-warning"><i class="fa-solid fa-star"></i> Total Reviews</h5>
                        <h2 class="display-5 fw-bold mt-2"><%= totalReviews %></h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Users Management Tab -->
    <div class="tab-pane fade" id="users-tab-pane" role="tabpanel" aria-labelledby="users-tab" tabindex="0">
        <h4 class="mb-3">Recent Users</h4>
        <div class="row row-cols-1 row-cols-md-3 g-4">
            <% for (let user of recentUsers) { %>
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body text-center p-4">
                            <div class="mb-3">
                                <i class="fa-solid fa-circle-user text-secondary" style="font-size: 3rem;"></i>
                            </div>
                            <h5 class="card-title fw-bold">@<%= user.username %></h5>
                            <p class="card-text text-muted mb-1"><%= user.email %></p>
                            <p class="card-text text-muted mb-3" style="font-size: 0.85rem;">
                                <i class="fa-regular fa-clock me-1"></i> Joined: <%= user._id.getTimestamp().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </p>
                            
                            <!-- Prevent admin from deleting themselves -->
                            <% if (user.email.toLowerCase().trim() !== process.env.ADMIN_EMAIL.toLowerCase().trim()) { %>
                                <form method="POST" action="/admin/users/<%= user._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this user? ALL their listings and reviews will be permanently deleted as well.');">
                                    <button class="btn btn-outline-danger w-100"><i class="fa-solid fa-trash me-1"></i> Delete User</button>
                                </form>
                            <% } else { %>
                                <span class="badge bg-secondary w-100 py-2">Super Admin</span>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% } %>
            <% if (recentUsers.length === 0) { %>
                <div class="col-12"><p class="text-muted">No users found.</p></div>
            <% } %>
        </div>
    </div>
    
    <!-- Listings Management Tab -->
    <div class="tab-pane fade" id="listings-tab-pane" role="tabpanel" aria-labelledby="listings-tab" tabindex="0">
        <h4 class="mb-3">Recent Listings</h4>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3 g-4">
            <% for (let listing of recentListings) { %>
                <div class="col">
                    <div class="card listing-card shadow-sm h-100">
                        <a href="/listings/<%=listing._id%>" class="listing-link" target="_blank">
                            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing-image" style="height:20rem" >
                            <div class="card-img-overlay"></div>
                        </a>
                        <div class="card-body p-3">
                            <p class="card-text mb-1">
                                <b><%=listing.title%></b>
                            </p>
                            <p class="card-text text-muted mb-2" style="font-size: 0.9rem;">
                                Owned by: @<%= listing.owner ? listing.owner.username : 'Unknown' %><br>
                                <i class="fa-regular fa-clock me-1"></i> Added: <%= listing._id.getTimestamp().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %><br>
                                &#8377; <%=listing.price ? listing.price.toLocaleString("en-IN") : '0' %> /night<br>
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                            <form method="POST" action="/admin/listings/<%= listing._id %>?_method=DELETE" onsubmit="return confirm('Are you sure you want to completely delete this listing?');">
                                <button class="btn btn-outline-danger w-100"><i class="fa-solid fa-trash me-1"></i> Delete Listing</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% } %>
            <% if (recentListings.length === 0) { %>
                <div class="col-12"><p class="text-muted">No listings found.</p></div>
            <% } %>
        </div>
    </div>

</div>
