<% layout("/layouts/boilerplate.ejs")%>
<div class="row mt-5 mb-5">
    <div class="col-12 col-md-6 offset-md-3">
        <div class="card shadow border-0 rounded-4 p-4 p-md-5 text-center">
            <div class="mb-4">
                <i class="fa-solid fa-envelope-circle-check text-primary" style="font-size: 4rem;"></i>
            </div>
            <h3 class="fw-bold mb-3">Verify Your Booking</h3>
            <p class="text-muted mb-4">
                We've sent a 6-digit One-Time Password (OTP) to your registered email address.<br>
                Please enter it below to confirm your reservation at <b><%= booking.listing.title %></b>.
            </p>
            
            <form action="/listings/<%= booking.listing._id %>/book/<%= booking._id %>/verify" method="POST" class="needs-validation" novalidate>
                <div class="mb-4 px-md-5">
                    <input type="text" name="otp" class="form-control form-control-lg text-center fw-bold fs-4" placeholder="••••••" maxlength="6" pattern="\d{6}" required>
                    <div class="invalid-feedback">
                        Please enter the 6-digit OTP.
                    </div>
                </div>
                
                <div class="d-grid gap-2 px-md-5">
                    <button type="submit" id="verifyBtn" class="btn btn-primary btn-lg rounded-pill fw-bold">Confirm Booking</button>
                    <a href="/listings/<%= booking.listing._id %>" class="btn btn-outline-secondary rounded-pill mt-2">Cancel</a>
                </div>
            </form>
            
            <div class="mt-4 pt-4 border-top">
                <p class="small text-muted mb-2">Total amount to be paid: <span class="fw-bold text-dark">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span></p>
                <div class="badge bg-danger rounded-pill px-3 py-2 fs-6 mb-3">
                    <i class="fa-regular fa-clock me-2"></i><span id="countdown">05:00</span>
                </div>
                <p id="expiredMsg" class="text-danger fw-bold mt-2 d-none">OTP Expired. Please cancel and book again.</p>
                
                <form action="/listings/<%= booking.listing._id %>/book/<%= booking._id %>/resend-otp" method="POST" id="resendForm">
                    <button type="submit" id="resendBtn" class="btn btn-sm btn-outline-primary rounded-pill fw-bold" disabled>
                        Resend OTP <span id="resendTimer">(02:00)</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        let timeLeft = 300; // 5 minutes for main expiration
        let resendLeft = 120; // 2 minutes for resend button
        
        const countdownEl = document.getElementById('countdown');
        const verifyBtn = document.getElementById('verifyBtn');
        const expiredMsg = document.getElementById('expiredMsg');
        
        const resendBtn = document.getElementById('resendBtn');
        const resendTimerEl = document.getElementById('resendTimer');
        
        const timer = setInterval(() => {
            if (timeLeft <= 0) {
                clearInterval(timer);
                countdownEl.innerText = "00:00";
                verifyBtn.disabled = true;
                verifyBtn.innerText = "Expired";
                expiredMsg.classList.remove('d-none');
                resendBtn.disabled = true; // Can't resend if completely expired, they should re-book
                return;
            }
            
            // Format Main Timer
            let m = Math.floor(timeLeft / 60);
            let s = timeLeft % 60;
            countdownEl.innerText = (m < 10 ? '0' : '') + m + ':' + (s < 10 ? '0' : '') + s;
            timeLeft--;
            
            // Handle Resend Timer
            if (resendLeft > 0) {
                let rm = Math.floor(resendLeft / 60);
                let rs = resendLeft % 60;
                resendTimerEl.innerText = `(${(rm < 10 ? '0' : '') + rm}:${(rs < 10 ? '0' : '') + rs})`;
                resendLeft--;
            } else {
                resendBtn.disabled = false;
                resendTimerEl.innerText = "";
            }
        }, 1000);

        // Async Email Trigger to prevent Vercel timeouts
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('initial') === 'true') {
            fetch(`/listings/<%= booking.listing._id %>/book/<%= booking._id %>/trigger-email`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            }).catch(console.error);
            // Remove 'initial' from URL so a refresh doesn't trigger it again
            window.history.replaceState({}, document.title, window.location.pathname);
        }
    });
</script>
