<% layout("/layouts/boilerplate.ejs")%>
<body>
    <div class="row">
        <div class="col-8 offset-2"><br><br>
            <h3>Create a new Listing</h3>

            <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input type="text" id="title" name="listing[title]" placeholder="enter title" class="form-control" required>
                    <div class="valid-feedback">
                        Title Looks good
                    </div>
                    <div class="invalid-feedback">
                        Please provide a valid title.
                    </div>
                </div>
                
                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea id="description" name="listing[description]" placeholder="enter description" class="form-control" required></textarea>
                    <div class="invalid-feedback">
                        Please provide a description.
                    </div>
                </div>
                
                <div class="mb-3">
                    <label for="category" class="form-label">Category</label>
                    <select id="category" name="listing[category]" class="form-select" required>
                        <option value="" disabled selected>Select a category</option>
                        <option value="Trending">Trending</option>
                        <option value="Rooms">Rooms</option>
                        <option value="Iconic cities">Iconic cities</option>
                        <option value="Mountains">Mountains</option>
                        <option value="Castles">Castles</option>
                        <option value="Amazing pools">Amazing pools</option>
                        <option value="Camping">Camping</option>
                        <option value="Farms">Farms</option>
                        <option value="Artic">Artic</option>
                        <option value="Domes">Domes</option>
                        <option value="Boats">Boats</option>
                    </select>
                    <div class="invalid-feedback">
                        Please select a category.
                    </div>
                </div>
            
                <div class="mb-3">
                    <label for="image" class="form-label">Image Upload</label>
                    <div class="input-group">
                        <input type="file" id="image" name="listing[image]" placeholder="Choose file" class="form-control" required>
                        <button type="button" class="btn btn-outline-primary d-none" id="aiImageBtn"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Auto-write Description</button>
                    </div>
                    <div class="invalid-feedback">
                        Please provide a valid image URL.
                    </div>
                </div>
                
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="price" class="form-label">Price</label>
                        <div class="input-group">
                            <span class="input-group-text">₹</span>
                            <input type="number" id="price" name="listing[price]" placeholder="enter price" class="form-control" min="1" step="0.01" required>
                            <button type="button" class="btn btn-outline-success" id="aiPriceBtn" title="Suggest Price"><i class="fa-solid fa-wand-magic-sparkles"></i></button>
                        </div>
                        <div class="invalid-feedback">
                            Please provide a valid price.
                        </div>
                    </div>
                
                    <div class="mb-3 col-md-8">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" id="country" name="listing[country]" placeholder="enter country" class="form-control" required>
                        <div class="invalid-feedback">
                            Please provide a country.
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="location" class="form-label">Location (City/Area)</label>
                    <input type="text" id="location" name="listing[location]" placeholder="enter location" class="form-control" required>
                    <div class="invalid-feedback">
                        Please provide a location.
                    </div>
                </div>

                <div class="mb-3">
                    <label for="address" class="form-label">Detailed Address (Optional)</label>
                    <textarea id="address" name="listing[address]" placeholder="enter exact address, e.g. 123 Main St, Apartment 4B" class="form-control" rows="2"></textarea>
                    <div class="form-text text-muted">This will be shared with guests after their booking is confirmed.</div>
                </div>

                <div class="row">
                    <div class="mb-3 col-md-6">
                        <label for="houseRules" class="form-label">House Rules</label>
                        <textarea id="houseRules" name="listing[houseRules]" placeholder="e.g. No smoking, no pets, check-out at 11 AM..." class="form-control" rows="3"></textarea>
                    </div>
                
                    <div class="mb-3 col-md-6">
                        <label for="cancellationPolicy" class="form-label">Cancellation Policy</label>
                        <textarea id="cancellationPolicy" name="listing[cancellationPolicy]" placeholder="e.g. Full refund up to 5 days before check-in..." class="form-control" rows="3"></textarea>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-dark add-btn">Add</button>
                <br>
                <br>
            </form>
        </div>
    </div>

<script>
    // --- AI Price Estimator ---
    document.getElementById('aiPriceBtn').addEventListener('click', async () => {
        const btn = document.getElementById('aiPriceBtn');
        const location = document.getElementById('location').value;
        const category = document.getElementById('category').value;
        const description = document.getElementById('description').value;

        if (!location) return alert("Please enter a location first to get a price estimate!");

        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
        btn.disabled = true;

        try {
            const res = await fetch('/listings/ai-estimate-price', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ location, category, description })
            });
            const data = await res.json();
            
            if (data.success) {
                document.getElementById('price').value = data.price;
            } else {
                showToast("AI service is currently busy. Please enter a price manually.");
            }
        } catch (e) {
            console.error(e);
            showToast("AI service is currently busy. Please enter a price manually.");
        } finally {
            btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles"></i>';
            btn.disabled = false;
        }
    });

    // --- AI Image Auto-Tagger ---
    const imageInput = document.getElementById('image');
    const aiImageBtn = document.getElementById('aiImageBtn');
    
    // Show button only when image is selected
    imageInput.addEventListener('change', () => {
        if (imageInput.files && imageInput.files[0]) {
            aiImageBtn.classList.remove('d-none');
        } else {
            aiImageBtn.classList.add('d-none');
        }
    });

    aiImageBtn.addEventListener('click', async () => {
        const file = imageInput.files[0];
        if (!file) return;

        aiImageBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Analyzing...';
        aiImageBtn.disabled = true;

        // Compress and convert to base64
        const reader = new FileReader();
        reader.onload = function(e) {
            const img = new Image();
            img.onload = async function() {
                const canvas = document.createElement('canvas');
                const MAX_WIDTH = 600;
                const scaleSize = MAX_WIDTH / img.width;
                canvas.width = MAX_WIDTH;
                canvas.height = img.height * scaleSize;
                const ctx = canvas.getContext('2d');
                ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                
                // Get base64 string without data url prefix
                const dataUrl = canvas.toDataURL('image/jpeg', 0.6);
                const base64Data = dataUrl.split(',')[1];

                try {
                    const res = await fetch('/listings/ai-analyze-image', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ imageBase64: base64Data })
                    });
                    const data = await res.json();
                    
                    if (data.success) {
                        const descField = document.getElementById('description');
                        descField.value = data.description + (descField.value ? "\n\n" + descField.value : "");
                    } else {
                        showToast("AI service is currently busy. Please write the description manually.");
                    }
                } catch (err) {
                    console.error(err);
                    showToast("AI service is currently busy. Please write the description manually.");
                } finally {
                    aiImageBtn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles me-2"></i>Auto-write Description';
                    aiImageBtn.disabled = false;
                }
            };
            img.src = e.target.result;
        };
        reader.readAsDataURL(file);
    });
</script>
</body>