<% layout("/layouts/boilerplate.ejs")%>
<link href="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.css" rel="stylesheet">
<script src="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
     let mapToken="<%=process.env.MAP_TOKEN%>";
     const listing = {
         title: <%- JSON.stringify(listing.title) %>,
         geometry: <%- JSON.stringify(listing.geometry) %>
     };
</script>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3 mt-3">
        
    <h1><%=listing.title%></h1>
    </div>
    <div class="card col-6 offset-3 show-card  listing-card">
        <img src="<%=listing.image.url.replace('/upload/', '/upload/f_auto,q_auto,w_1200/')%>" class="card-img-top show-img" alt="listing_image" fetchpriority="high" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80';">
    <div class="card-body">
     
        <p class="card-text mt-3">
            <div class="d-flex align-items-center mb-3 p-3 bg-body-tertiary rounded-3 border">
                <i class="fa-solid fa-circle-user text-primary fs-2 me-3"></i>
                <div>
                    <p class="mb-0 fw-bold fs-5">Hosted by <%=listing.owner.username%></p>
                    <p class="mb-0 small text-muted">
                        <% if(hostAverageRating === 'New') { %>
                            <span class="badge bg-secondary">New Host</span> (No reviews yet)
                        <% } else { %>
                            <span class="badge bg-success"><i class="fa-solid fa-star me-1"></i><%= hostAverageRating %></span>
                            <span>(<%= totalHostReviews %> <%= totalHostReviews === 1 ? 'review' : 'reviews' %>)</span>
                        <% } %>
                    </p>
                </div>
            </div>
            <p class="card-text text-muted" style="font-size: 0.9rem;"><i class="fa-regular fa-clock me-1"></i> Added on <%=listing._id.getTimestamp().toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })%></p>
            <p class="card-text"> <%=listing.description%></p>
           <p class="card-text"> &#8377; <%=listing.price.toLocaleString("en-IN")%></p>
            <p class="card-text"><%=listing.location%></p>
           <p class="card-text">  <%=listing.country%></p>

        </p>
        
  </div>




    </div>
    
    <!-- Booking Section -->
    <div class="col-6 offset-3 mt-4">
        <div class="card shadow-sm border-0 rounded-4 p-4">
            <h4 class="fw-bold mb-4">Book this property</h4>
            <% if (currUser) { %>
                <form action="/listings/<%= listing._id %>/book/checkout" method="GET" id="bookingForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Check-in</label>
                            <input type="text" id="checkIn" name="booking[checkIn]" class="form-control" placeholder="Select date" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Check-out</label>
                            <input type="text" id="checkOut" name="booking[checkOut]" class="form-control" placeholder="Select date" required>
                        </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <div>
                            <span class="fs-5 fw-bold">&#8377; <%= listing.price.toLocaleString("en-IN") %></span> <span class="text-muted">/ night</span>
                        </div>
                        <button type="submit" class="btn btn-primary px-4 py-2 rounded-pill fw-bold">Continue to Booking</button>
                    </div>
                </form>
                <script>
                    const bookedDates = <%- JSON.stringify(bookedDates || []) %>;
                    
                    document.addEventListener("DOMContentLoaded", function() {
                        const checkInPicker = flatpickr("#checkIn", {
                            minDate: "today",
                            disable: bookedDates,
                            onChange: function(selectedDates, dateStr, instance) {
                                checkOutPicker.set('minDate', new Date(selectedDates[0].getTime() + 24 * 60 * 60 * 1000));
                            }
                        });
                        const checkOutPicker = flatpickr("#checkOut", {
                            minDate: new Date(new Date().getTime() + 24 * 60 * 60 * 1000),
                            disable: bookedDates
                        });
                    });
                </script>
            <% } else { %>
                <div class="text-center py-3">
                    <p class="text-muted mb-3">You must be logged in to book this property.</p>
                    <a href="/login" class="btn btn-outline-primary px-4 rounded-pill">Log in to Book</a>
                </div>
            <% } %>
        </div>
    </div>
   
    <div class="col-8 offset-3 mt-4">
        <hr>
        <div class="row">
            <div class="col-md-6 mb-3 mb-md-0">
                <p class="mb-2"><i class="fa-solid fa-person text-secondary me-2"></i><b>Max Guests:</b> <%= listing.maxGuests || 6 %></p>
                <p class="mb-2"><i class="fa-solid fa-list-check text-secondary me-2"></i><b>House Rules:</b> <%= listing.houseRules || 'No specific rules provided.' %></p>
                <p class="mb-0"><i class="fa-solid fa-ban text-secondary me-2"></i><b>Cancellation:</b> <%= listing.cancellationPolicy || 'Flexible - Full refund up to 24 hours before check-in.' %></p>
            </div>
            <div class="col-md-6 d-flex flex-column align-items-start justify-content-center">
                <p class="mb-2 text-muted small"><i class="fa-solid fa-wand-magic-sparkles text-primary me-2"></i>Not sure what to do in <%= listing.location %>?</p>
                <button id="aiItineraryBtn" class="btn btn-outline-primary rounded-pill px-4 fw-bold">
                    <i class="fa-regular fa-map me-2"></i>Plan My Trip
                </button>
            </div>
        </div>

        <div id="aiItineraryContainer" class="mt-4 p-4 bg-body-tertiary rounded-4 shadow-sm border d-none">
            <h4 class="fw-bold mb-3"><i class="fa-solid fa-plane-departure text-primary me-2"></i>Your AI Itinerary</h4>
            <div id="aiItineraryContent"></div>
        </div>
    </div>
    
    <script>
        document.getElementById('aiItineraryBtn')?.addEventListener('click', async () => {
            const btn = document.getElementById('aiItineraryBtn');
            const container = document.getElementById('aiItineraryContainer');
            const content = document.getElementById('aiItineraryContent');

            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Planning...';
            btn.disabled = true;

            try {
                const response = await fetch(`/listings/<%=listing._id%>/ai-itinerary`);
                const data = await response.json();

                if (data.success) {
                    content.innerHTML = typeof marked !== 'undefined' ? marked.parse(data.itinerary) : data.itinerary;
                    container.classList.remove('d-none');
                    btn.style.display = 'none'; // Hide button after generating
                } else {
                    alert(data.error || 'Failed to generate itinerary.');
                    btn.innerHTML = '<i class="fa-regular fa-map me-2"></i>Plan My Trip';
                    btn.disabled = false;
                }
            } catch (error) {
                alert('Error contacting AI service.');
                btn.innerHTML = '<i class="fa-regular fa-map me-2"></i>Plan My Trip';
                btn.disabled = false;
            }
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <% if(currUser && currUser._id.equals(listing.owner._id)) { %>

    <div class="row btns g-2">
        <div class="col-12 col-md-2 offset-md-3">
    <a href="/listings/<%=listing._id%>/edit" class="btn btn-dark w-100 edit-btn">Edit</a>
            </div>
    

            <div class="col-12 col-md-2">
    <form method="POST" action="/listings/<%=listing.id%>?_method=DELETE" onsubmit="return confirm('Are you sure you want to delete this listing?');">
        <button class="btn btn-dark w-100">Delete</button>
    </form>
    </div>


    </div>
    <% } %>
   
    
    <div class="col-8 offset-3 mt-3 mb-3">
        
        <% if (currUser) { %>
            <hr>
             
             
        <h4>Leave a Review</h4>

        <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <!-- <div class="mb-3 mt-3">
                <label for="rating" class="form-label">Rating</label>
                <input type="range" class="form-range" min="1" max="5" id="rating" name="review[rating]">
            </div> -->
            <div class="mb-3 mt-3">
             <label for="rating" class="form-label">Rating</label>   
            <fieldset class="starability-slot">
                
            
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset></div>
            <div class="mb-3">
                <label for="comment">Comment</label>
                <textarea
                name="review[comment]"
                id="comment"
                cols="30"
                row="5"
                 class="form-control"   required></textarea>
                </textarea>
                  
                <div class="invalid-feedback">
                    Please Enter the review
                </div>
            </div>
            <button lass="btn btn-outline-dark">Submit</button>
        </form>
        <hr>
        <% } %>
        
        
        <% if(listing.reviews.length>0){%>
        <div class="row position-relative">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <p class="m-0 fs-5"><b>All Reviews</b></p>
                <button id="aiSummaryBtn" class="btn btn-sm btn-primary rounded-pill px-3 py-2" style="background: linear-gradient(45deg, #7c3aed, #4f46e5); border: none;">
                    <i class="fa-solid fa-wand-magic-sparkles me-2"></i>Generate Honest AI Summary
                </button>
            </div>
            
    <div id="aiSummaryContainer" class="col-12 mb-4 d-none">
        <div class="row">
            <div class="col-md-6 mb-3 mb-md-0">
                <div class="bg-body-tertiary p-3 rounded-3 h-100 shadow-sm border border-success border-opacity-25">
                    <h6 class="text-success fw-bold"><i class="fa-solid fa-circle-check me-2"></i>The Good</h6>
                    <ul id="aiGoodList" class="mb-0 small text-body-secondary"></ul>
                </div>
            </div>
            <div class="col-md-6">
                <div class="bg-body-tertiary p-3 rounded-3 h-100 shadow-sm border border-danger border-opacity-25">
                    <h6 class="text-danger fw-bold"><i class="fa-solid fa-flag me-2"></i>Hidden Red Flags</h6>
                    <ul id="aiBadList" class="mb-0 small text-body-secondary"></ul>
                </div>
            </div>
        </div>
    </div>

            <script>
                document.getElementById('aiSummaryBtn').addEventListener('click', async () => {
                    const btn = document.getElementById('aiSummaryBtn');
                    const container = document.getElementById('aiSummaryContainer');
                    const goodList = document.getElementById('aiGoodList');
                    const badList = document.getElementById('aiBadList');

                    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Analyzing Reviews...';
                    btn.disabled = true;

                    try {
                        const response = await fetch('/listings/<%=listing._id%>/ai-summary');
                        const data = await response.json();

                        if (data.success) {
                            goodList.innerHTML = data.summary.theGood.map(item => `<li>${item}</li>`).join('');
                            badList.innerHTML = data.summary.redFlags.length > 0 ? 
                                data.summary.redFlags.map(item => `<li>${item}</li>`).join('') : 
                                '<li><i>No major red flags found!</i></li>';
                            
                            container.classList.remove('d-none');
                            btn.style.display = 'none';
                        } else {
                            alert(data.error || 'Failed to generate summary.');
                            btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles me-2"></i>Try Again';
                            btn.disabled = false;
                        }
                    } catch (error) {
                        alert('Error contacting AI service.');
                        btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles me-2"></i>Try Again';
                        btn.disabled = false;
                    }
                });
            </script>
        <% for (review of listing.reviews){ %>
            
           <div class="card col-12 col-md-5 ms-3 mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h5 class="card-title">@ <%=review.author.username%></h5>
                    <% if(currUser && currUser._id.equals(review.author._id)) { %>
                        <div class="d-flex gap-2">
                            <a href="/listings/<%=listing._id%>/reviews/<%=review._id%>/edit" class="btn btn-sm btn-outline-dark border-0" aria-label="Edit Review" title="Edit Review"><i class="fa-solid fa-pencil"></i></a>
                            <form method="POST" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE" style="margin:0;" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger border-0" aria-label="Delete Review" title="Delete Review"><i class="fa-solid fa-trash"></i></button>
                            </form>
                        </div>
                    <% } %>
                </div>
                  <p class="starability-result card-text mt-1" data-rating=<%=review.rating%>></p>
                <p class="card-text"><%=review.comment%></p>
            </div>
           </div>

       <% } %>
       </div>
       <%}%>
    </div>
    <div class="col-4 offset-4 col-md-6 offset-md-3 mt-3 mb-3">
        <h3>Where you'll be</h3>
        <div id="map"></div>
        

            


    </div>
<script src="/js/map.js"></script>



  
</body>
