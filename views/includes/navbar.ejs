<style>
.btn-search{
  background-color: #fe424d;
  color:white;
  border-radius:25px;
  padding:0 1rem 0 1rem;
  

}
.btn-search:hover{
  background-color: #fe424d;
  color:white;

}
.btn-search>i{
  display:inline; 
  margin-right:0.5rem;
}
.search-input{
   border-radius:25px;
   padding:0.5rem 2rem 0.5rem 2rem;

}
@media (min-width: 768px) {
  .absolute-center {
    position: absolute !important;
    left: 50% !important;
    transform: translateX(-50%) !important;
  }
}
</style>
<nav class="navbar navbar-expand-md border-bottom sticky-top">
  <div class="container-fluid position-relative">
    <a class="navbar-brand" href="/listings" aria-label="BookVilla Home"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav me-auto" style="flex: 1;">
        <br>
       
        <a class="nav-link" href="/listings">Explore</a>
        
        </div>
        <div class="navbar-nav mx-auto my-2 my-md-0 justify-content-center absolute-center" style="width: 100%; max-width: 600px; z-index: 1050;">
          <form action="/listings/search" method="GET" class="d-flex align-items-center bg-body-tertiary rounded-pill p-1 shadow-sm border w-100" style="transition: all 0.3s ease;">
            <div class="d-flex w-100 align-items-center position-relative dropdown" id="searchDropdownParent">
                <!-- Location Input -->
                <input type="text" id="locationSearchInput" name="search" class="form-control bg-transparent border-0 shadow-none" data-bs-toggle="dropdown" aria-expanded="false" placeholder="Where?" autocomplete="off" value="<%= typeof searchQuery !== 'undefined' ? searchQuery.search || '' : '' %>" required>
                <ul class="dropdown-menu w-100 shadow-sm rounded-4 mt-2 border-0" id="autocompleteDropdown" style="max-height: 250px; overflow-y: auto;">
                    <!-- Autocomplete items -->
                </ul>
                
                <div class="vr mx-2 text-secondary"></div>
                
                <!-- Dates Input -->
                <input type="text" id="checkInInput" name="checkIn" class="form-control bg-transparent border-0 shadow-none px-1 text-center" placeholder="From" style="font-size: 0.9rem; width: 100px;" value="<%= typeof searchQuery !== 'undefined' ? searchQuery.checkIn || '' : '' %>">
                <span class="text-muted mx-1">-</span>
                <input type="text" id="checkOutInput" name="checkOut" class="form-control bg-transparent border-0 shadow-none px-1 text-center" placeholder="To" style="font-size: 0.9rem; width: 100px;" value="<%= typeof searchQuery !== 'undefined' ? searchQuery.checkOut || '' : '' %>">
                
                <div class="vr mx-2 text-secondary"></div>
                
                <!-- Guests Input -->
                <input type="number" name="guests" class="form-control bg-transparent border-0 shadow-none ps-2" placeholder="Guests" min="1" style="width: 90px;" value="<%= typeof searchQuery !== 'undefined' ? searchQuery.guests || '' : '' %>">
            </div>
            <button type="submit" class="btn btn-primary rounded-circle d-flex justify-content-center align-items-center p-0 flex-shrink-0 me-1" style="width: 38px; height: 38px; background: #fe424d; border: none;">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
          </form>
        </div>
        <div class="navbar-nav ms-auto align-items-center justify-content-md-end" style="flex: 1;">
          <button id="theme-toggle" class="btn btn-sm btn-outline-secondary me-2 rounded-circle d-flex justify-content-center align-items-center" style="width: 32px; height: 32px;" aria-label="Toggle Theme">
            <i class="fa-solid fa-moon"></i>
          </button>
          <a class="nav-link" href="/listings/new">BookVilla&nbsp; your&nbsp; home</a>
         <% if(!currUser){ %>
        <a class="nav-link" href="/login"><b>Log in</b></a>
          <%}%>
          <% if(currUser){ %>
            <div class="nav-item dropdown ms-2">
              <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="fa-solid fa-user-circle fs-5"></i>
              </a>
              <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2" aria-labelledby="navbarDropdown" style="min-width: 260px;">
                <li class="px-3 py-3 border-bottom mb-2 text-center">
                  <div class="mb-2">
                    <i class="fa-solid fa-circle-user text-primary" style="font-size: 3.5rem;"></i>
                  </div>
                  <span class="d-block fw-bold text-body fs-5"><%= currUser.username %></span>
                  <small class="text-body-secondary"><%= currUser.email %></small>
                </li>
                <li><a class="dropdown-item fw-semibold py-2" href="/profile"><i class="fa-solid fa-suitcase-rolling me-3 text-info"></i>Booking History</a></li>
                <li><a class="dropdown-item fw-semibold py-2" href="/profile"><i class="fa-solid fa-id-badge me-3 text-primary"></i>Your Profile</a></li>
                <% if(currUser.username === 'admin' || (process.env.ADMIN_EMAIL && currUser.email === process.env.ADMIN_EMAIL)) { %>
                  <li><a class="dropdown-item fw-semibold py-2" href="/admin"><i class="fa-solid fa-shield-halved me-3 text-warning"></i>Admin Panel</a></li>
                <% } %>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item fw-semibold text-danger py-2" href="/logout"><i class="fa-solid fa-right-from-bracket me-3"></i>Log out</a></li>
              </ul>
            </div>
         <% } %>
        
      
    </div>
  </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('locationSearchInput');
    const dropdown = document.getElementById('autocompleteDropdown');
    const bsDropdown = new bootstrap.Dropdown(searchInput);
    
    let debounceTimer;
    
    searchInput.addEventListener('input', (e) => {
        clearTimeout(debounceTimer);
        const query = e.target.value.trim();
        
        if (query.length < 1) {
            dropdown.innerHTML = '';
            bsDropdown.hide();
            return;
        }
        
        debounceTimer = setTimeout(async () => {
            try {
                const response = await fetch(`/listings/search/autocomplete?q=${encodeURIComponent(query)}`);
                const data = await response.json();
                
                if (data.suggestions && data.suggestions.length > 0) {
                    dropdown.innerHTML = data.suggestions.map(s => 
                        `<li><a class="dropdown-item py-2" href="#" onclick="document.getElementById('locationSearchInput').value='${s}'; return false;"><i class="fa-solid fa-location-dot text-muted me-2"></i>${s}</a></li>`
                    ).join('');
                    bsDropdown.show();
                } else {
                    dropdown.innerHTML = `<li><span class="dropdown-item text-muted py-2">No matches found</span></li>`;
                    bsDropdown.show();
                }
            } catch (err) {
                console.error('Autocomplete fetch error:', err);
            }
        }, 300);
    });
    
    // Make location optional since dates and guests are other ways to search
    searchInput.required = false;

    // Initialize Flatpickr for date inputs
    if (typeof flatpickr !== 'undefined') {
        const checkInPicker = flatpickr("#checkInInput", {
            altInput: true,
            altFormat: "d M Y",
            dateFormat: "Y-m-d",
            minDate: "today",
            onChange: function(selectedDates, dateStr, instance) {
                checkOutPicker.set("minDate", selectedDates[0] ? new Date(selectedDates[0]).fp_incr(1) : "today");
            }
        });

        const checkOutPicker = flatpickr("#checkOutInput", {
            altInput: true,
            altFormat: "d M Y",
            dateFormat: "Y-m-d",
            minDate: "today"
        });
    }
});
</script>