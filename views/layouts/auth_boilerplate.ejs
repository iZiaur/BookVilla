<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BookVilla - Authentication</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" integrity="sha512-Evv84Mr4kqVGRNSgIGL/F/aIDqQb7xQ2vcrdIwxfjThSH8CSR7PBEakCr51Ck+w+/U6swU2Im1vVX0SVk9ABhg==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        .auth-bg {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden; /* Prevent scrollbar from scaled pseudo-element */
        }

        /* The actual blurred background image */
        .auth-bg::before {
            content: "";
            position: absolute;
            top: -20px; right: -20px; bottom: -20px; left: -20px; /* Slight bleed to prevent white edges when blurred */
            background-image: url('https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?ixlib=rb-4.0.3&auto=format&fit=crop&w=2075&q=80');
            background-position: center;
            background-repeat: no-repeat;
            background-size: cover;
            filter: blur(12px);
            z-index: 0;
        }

        /* Overlay to darken background slightly for contrast */
        .auth-bg::after {
            content: "";
            position: absolute;
            top: 0; right: 0; bottom: 0; left: 0;
            background: rgba(0, 0, 0, 0.4);
            z-index: 1;
        }

        /* Glassmorphism Card */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border-radius: 1.5rem;
            border: 1px solid rgba(255, 255, 255, 0.5);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
            z-index: 2;
            width: 100%;
            max-width: 450px;
            padding: 2.5rem;
            position: relative;
        }

        .auth-logo {
            font-size: 2rem;
            color: #dc3545;
            font-weight: 700;
            text-align: center;
            margin-bottom: 1rem;
            text-decoration: none;
            display: block;
        }

        .auth-logo:hover {
            color: #bb2d3b;
        }
    </style>
</head>
<body>
    <%- include("../includes/flash.ejs") %>
    <div class="auth-bg">
        
        <div class="glass-card">
            <a href="/listings" class="auth-logo"><i class="fa-regular fa-compass"></i> BookVilla</a>
            <%- body %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
    <script src="/js/script.js"></script>
</body>
</html>
