<% layout("/layouts/auth_boilerplate.ejs")%>

<div class="text-center mb-4">
    <h3 class="fw-bold">Forgot Password</h3>
    <p class="text-muted">Enter your email address and we will send you a link to reset your password.</p>
</div>

<form action="/forgot-password" method="POST" class="needs-validation" novalidate>
    <div class="mb-4">
        <label for="email" class="form-label fw-semibold">Email</label>
        <div class="input-group">
            <span class="input-group-text bg-body-tertiary"><i class="fa-solid fa-envelope"></i></span>
            <input type="email" id="email" name="email" class="form-control" pattern="^[^\s@]+@[^\s@]+\.[^\s@]+$" title="Please provide a valid email address." required placeholder="name@example.com">
            <div class="invalid-feedback">Please provide a valid email address.</div>
        </div>
    </div>
    
    <button type="submit" class="btn btn-danger w-100 py-2 fw-bold rounded-3 mb-3">Send Reset Link</button>
    
    <div class="text-center mt-3">
        <a href="/login" class="text-decoration-none fw-bold text-body"><i class="fa-solid fa-arrow-left me-1"></i> Back to Login</a>
    </div>
</form>
