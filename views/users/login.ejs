<% layout("/layouts/boilerplate.ejs")%>

<div class="row mt-5 mb-5">
    <div class="col-md-6 offset-md-3 col-lg-4 offset-lg-4">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-4 p-md-5">
                
                <!-- Login Section -->
                <div id="loginSection" class="<%= typeof mode !== 'undefined' && mode === 'signup' ? 'd-none' : '' %>">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Welcome Back</h2>
                        <p class="text-muted">Please log in to your account.</p>
                    </div>
                    
                    <form action="/login" method="POST" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="login-username" class="form-label fw-semibold">Username or Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-solid fa-user"></i></span>
                                <input type="text" id="login-username" name="username" class="form-control" required placeholder="Enter username or email">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="login-password" class="form-label fw-semibold">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-solid fa-lock"></i></span>
                                <input type="password" id="login-password" name="password" class="form-control" required placeholder="Enter password">
                                <button class="btn btn-outline-secondary toggle-password bg-light" type="button" aria-label="Show password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        
                        <button class="btn btn-dark w-100 py-2 fw-bold rounded-3 mb-3">Log In</button>
                        
                        <div class="text-center mt-3">
                            <span class="text-muted">New user? </span>
                            <a href="#" id="showSignupBtn" class="text-decoration-none fw-bold text-dark">Sign up here</a>
                        </div>
                    </form>
                </div>

                <!-- Signup Section -->
                <div id="signupSection" class="<%= typeof mode !== 'undefined' && mode === 'signup' ? '' : 'd-none' %>">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold">Create Account</h2>
                        <p class="text-muted">Join BookVilla today.</p>
                    </div>
                    
                    <form action="/signup" method="POST" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label for="signup-username" class="form-label fw-semibold">Username</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-solid fa-at"></i></span>
                                <input type="text" id="signup-username" name="username" class="form-control" required placeholder="Choose a username">
                                <div class="invalid-feedback">Please provide a Username.</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="signup-email" class="form-label fw-semibold">Email</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-solid fa-envelope"></i></span>
                                <input type="email" id="signup-email" name="email" class="form-control" pattern=".*\.com$" title="Email must end with .com" required placeholder="name@example.com">
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="signup-password" class="form-label fw-semibold">Password</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="fa-solid fa-lock"></i></span>
                                <input type="password" id="signup-password" name="password" class="form-control" required placeholder="Create a password">
                                <button class="btn btn-outline-secondary toggle-password bg-light" type="button" aria-label="Show password">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        
                        <button class="btn btn-danger w-100 py-2 fw-bold rounded-3 mb-3">Sign Up</button>
                        
                        <div class="text-center mt-3">
                            <span class="text-muted">Already have an account? </span>
                            <a href="#" id="showLoginBtn" class="text-decoration-none fw-bold text-dark">Log in here</a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>

<script>
    // Handle form toggling
    document.getElementById('showSignupBtn').addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('loginSection').classList.add('d-none');
        document.getElementById('signupSection').classList.remove('d-none');
        // Update URL without reloading to reflect state if they refresh
        window.history.pushState({}, '', '/login?mode=signup');
    });

    document.getElementById('showLoginBtn').addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('signupSection').classList.add('d-none');
        document.getElementById('loginSection').classList.remove('d-none');
        window.history.pushState({}, '', '/login');
    });

    // Handle password visibility toggle
    document.querySelectorAll('.toggle-password').forEach(button => {
        button.addEventListener('click', function() {
            const input = this.previousElementSibling;
            const icon = this.querySelector('i');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.remove('fa-eye');
                icon.classList.add('fa-eye-slash');
                
                setTimeout(() => {
                    input.type = 'password';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }, 2000);
            }
        });
    });
</script>