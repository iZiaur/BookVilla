<% layout("/layouts/boilerplate.ejs")%>
<div class="row mt-4 mb-5">
    <div class="col-12 col-md-10 offset-md-1 col-lg-8 offset-lg-2">
        <div class="card shadow-sm border-0 mb-5 p-4 rounded-4 text-center bg-light">
            <div class="mb-3">
                <i class="fa-solid fa-circle-user text-primary" style="font-size: 5rem;"></i>
            </div>
            <h2 class="fw-bold mb-1"><%= currUser.username %></h2>
            <p class="text-muted fs-5"><i class="fa-solid fa-envelope me-2"></i><%= currUser.email %></p>
        </div>

        <h3 class="fw-bold mb-4 border-bottom pb-2">Your Properties (<%= listings.length %>)</h3>
        <% if(listings.length === 0) { %>
            <div class="alert alert-light border shadow-sm text-center py-4 rounded-4">
                <i class="fa-solid fa-house-chimney text-muted fs-1 mb-3"></i>
                <h5>You haven't posted any properties yet.</h5>
                <a href="/listings/new" class="btn btn-primary mt-2 rounded-pill px-4">Create one now</a>
            </div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mb-5">
                <% for(let listing of listings) { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                            <a href="/listings/<%= listing._id %>">
                                <img src="<%= listing.image.url %>" class="card-img-top" alt="Property Image" style="height: 160px; object-fit: cover;" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80';">
                            </a>
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold text-truncate mb-1"><a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark"><%= listing.title %></a></h6>
                                <p class="card-text text-muted small mb-2 text-truncate"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></p>
                                <span class="badge bg-secondary rounded-pill px-3 py-2"><%= listing.category || 'Uncategorized' %></span>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>

        <h3 class="fw-bold mb-4 border-bottom pb-2 mt-5">Reviews on Your Properties</h3>
        <% 
            let hasReviews = false;
            for(let listing of listings) {
                if(listing.reviews && listing.reviews.length > 0) {
                    hasReviews = true;
                }
            }
        %>
        
        <% if(!hasReviews) { %>
            <div class="alert alert-light border shadow-sm text-center py-4 rounded-4">
                <i class="fa-regular fa-comments text-muted fs-1 mb-3"></i>
                <h5 class="text-muted">No reviews received yet.</h5>
            </div>
        <% } else { %>
            <div class="list-group mb-5 shadow-sm rounded-4">
                <% for(let listing of listings) { %>
                    <% if(listing.reviews && listing.reviews.length > 0) { %>
                        <div class="list-group-item bg-light text-dark fw-bold border-bottom-0 mt-3 first-of-type:mt-0"><i class="fa-solid fa-house me-2 text-primary"></i><%= listing.title %></div>
                        <% for(let review of listing.reviews) { %>
                            <div class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-semibold"><i class="fa-solid fa-circle-user me-2 text-secondary fs-5 align-middle"></i><%= review.author.username %></span>
                                    <p class="starability-result m-0" style="transform: scale(0.7); transform-origin: right;" data-rating="<%= review.rating %>"></p>
                                </div>
                                <p class="mb-0 text-muted fst-italic">"<%= review.comment %>"</p>
                            </div>
                        <% } %>
                    <% } %>
                <% } %>
            </div>
        <% } %>
    </div>
</div>
