<% layout("/layouts/boilerplate.ejs")%>
<div class="row mt-4 mb-5 px-md-4">
    <!-- Sidebar -->
    <div class="col-12 col-md-4 col-lg-3 mb-4">
        <div class="card shadow-sm border-0 p-4 rounded-4 text-center bg-body-tertiary position-sticky" style="top: 2rem;">
            <div class="mb-3">
                <i class="fa-solid fa-circle-user text-primary" style="font-size: 6rem;"></i>
            </div>
            <h2 class="fw-bold mb-2"><%= currUser.username %></h2>
            <p class="text-muted mb-3"><i class="fa-solid fa-envelope me-2"></i><%= currUser.email %></p>
            <button class="btn btn-sm btn-outline-secondary rounded-pill w-100" data-bs-toggle="modal" data-bs-target="#editEmailModal"><i class="fa-solid fa-pen me-2"></i>Edit Email</button>
        </div>
    </div>
    
    <!-- Main Content -->
    <div class="col-12 col-md-8 col-lg-9 ps-md-4">

        <h3 class="fw-bold mb-4 border-bottom pb-2">Your Bookings (<%= bookings ? bookings.length : 0 %>)</h3>
        <% if(!bookings || bookings.length === 0) { %>
            <div class="alert bg-body-tertiary border shadow-sm text-center py-4 rounded-4 mb-5">
                <i class="fa-solid fa-suitcase-rolling text-muted fs-1 mb-3"></i>
                <h5>You have no upcoming trips.</h5>
                <a href="/listings" class="btn btn-primary mt-2 rounded-pill px-4">Start exploring</a>
            </div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-md-2 g-4 mb-5">
                <% for(let booking of bookings) { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                            <div class="card-body p-4 position-relative">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <h5 class="card-title fw-bold text-truncate mb-0" style="max-width: 70%;"><a href="/listings/<%= booking.listing._id %>" class="text-decoration-none text-body"><%= booking.listing.title %></a></h5>
                                    <% if(booking.status === "Confirmed") { %>
                                        <span class="badge bg-success rounded-pill px-3 py-2"><i class="fa-solid fa-check-circle me-1"></i> Confirmed</span>
                                    <% } else if(booking.status === "Awaiting Payment") { %>
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="fa-solid fa-credit-card me-1"></i> Awaiting Payment</span>
                                    <% } else { %>
                                        <span class="badge bg-warning text-dark rounded-pill px-3 py-2"><i class="fa-solid fa-clock me-1"></i> <%= booking.status %></span>
                                    <% } %>
                                </div>
                                
                                <p class="text-muted small mb-3"><i class="fa-solid fa-location-dot me-1"></i><%= booking.listing.location %>, <%= booking.listing.country %></p>
                                
                                <div class="d-flex justify-content-between align-items-center bg-body-tertiary p-3 rounded-3 mb-3">
                                    <div>
                                        <p class="small text-muted mb-0 text-uppercase fw-bold">Check-in</p>
                                        <p class="mb-0 fw-semibold"><%= new Date(booking.checkIn).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                    </div>
                                    <div class="text-center text-muted">
                                        <i class="fa-solid fa-arrow-right"></i>
                                    </div>
                                    <div class="text-end">
                                        <p class="small text-muted mb-0 text-uppercase fw-bold">Check-out</p>
                                        <p class="mb-0 fw-semibold"><%= new Date(booking.checkOut).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
                                    </div>
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center border-top pt-3">
                                    <span class="text-muted">Total Paid</span>
                                    <span class="fs-5 fw-bold">&#8377; <%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                </div>
                                
                                <% if(booking.status === "Confirmed" && booking.listing.owner) { %>
                                    <div class="mt-3 p-3 bg-body-tertiary rounded-3 border">
                                        <p class="small text-muted mb-2 text-uppercase fw-bold">Contact Host & Property Details</p>
                                        <p class="mb-1 fw-semibold"><i class="fa-solid fa-user me-2 text-primary"></i><%= booking.listing.owner.username %></p>
                                        <p class="mb-1 small"><i class="fa-solid fa-envelope me-2 text-secondary"></i><a href="mailto:<%= booking.listing.owner.email %>" class="text-decoration-none"><%= booking.listing.owner.email %></a></p>
                                        <p class="mb-1 small"><i class="fa-solid fa-phone me-2 text-secondary"></i><%= booking.listing.owner.phone || 'Not provided' %></p>
                                        <hr class="my-2">
                                        <% if(booking.listing.address) { %>
                                            <p class="mb-1 small"><i class="fa-solid fa-map-location-dot me-2 text-danger"></i><strong><%= booking.listing.address %></strong></p>
                                            <p class="mb-2 small ms-4 text-muted"><%= booking.listing.location %>, <%= booking.listing.country %></p>
                                        <% } else { %>
                                            <p class="mb-2 small"><i class="fa-solid fa-map-location-dot me-2 text-danger"></i><%= booking.listing.location %>, <%= booking.listing.country %></p>
                                        <% } %>
                                        
                                        <button class="btn btn-sm btn-outline-primary w-100 rounded-pill mt-2 welcome-guide-btn" data-booking-id="<%= booking._id %>" data-listing-id="<%= booking.listing._id %>">
                                            <i class="fa-solid fa-wand-magic-sparkles me-1"></i> View Welcome Guide
                                        </button>
                                    </div>
                                <% } %>
                                
                                <% if(booking.status === "Pending") { %>
                                    <div class="mt-3 text-center">
                                        <a href="/listings/<%= booking.listing._id %>/book/<%= booking._id %>/verify" class="btn btn-sm btn-outline-primary rounded-pill w-100">Verify OTP to Confirm</a>
                                    </div>
                                <% } %>

                                <% if(booking.status === "Awaiting Payment") { %>
                                    <div class="mt-3 text-center">
                                        <a href="/listings/<%= booking.listing._id %>/book/<%= booking._id %>/pay" class="btn btn-sm btn-dark rounded-pill w-100"><i class="fa-solid fa-credit-card me-1"></i> Complete Payment</a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>

        <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
            <h3 class="fw-bold mb-0">Your Properties (<%= listings.length %>)</h3>
            <% if(listings.length > 0) { %>
                <button id="hostAnalyticsBtn" class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold">
                    <i class="fa-solid fa-chart-line me-2"></i> AI Host Insights
                </button>
            <% } %>
        </div>
        
        <div id="hostAnalyticsContainer" class="mb-5 p-4 bg-body-tertiary rounded-4 shadow-sm border d-none">
            <h4 class="fw-bold mb-3"><i class="fa-solid fa-robot text-success me-2"></i>AI Business Analysis</h4>
            <div id="hostAnalyticsContent"></div>
        </div>

        <% if(listings.length === 0) { %>
            <div class="alert bg-body-tertiary border shadow-sm text-center py-4 rounded-4">
                <i class="fa-solid fa-house-chimney text-muted fs-1 mb-3"></i>
                <h5>You haven't posted any properties yet.</h5>
                <a href="/listings/new" class="btn btn-primary mt-2 rounded-pill px-4">Create one now</a>
            </div>
        <% } else { %>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-4 mb-5">
                <% for(let listing of listings) { %>
                    <div class="col">
                        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
                            <a href="/listings/<%= listing._id %>">
                                <img src="<%= listing.image.url %>" class="card-img-top" alt="Property Image" style="height: 160px; object-fit: cover;" onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80';">
                            </a>
                            <div class="card-body p-3">
                                <h6 class="card-title fw-bold text-truncate mb-1"><a href="/listings/<%= listing._id %>" class="text-decoration-none text-body"><%= listing.title %></a></h6>
                                <p class="card-text text-muted small mb-2 text-truncate"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></p>
                                <span class="badge bg-secondary rounded-pill px-3 py-2"><%= listing.category || 'Uncategorized' %></span>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        <% } %>

        <h3 class="fw-bold mb-4 border-bottom pb-2 mt-5">Reviews on Your Properties</h3>
        <% 
            let hasReviews = false;
            for(let listing of listings) {
                if(listing.reviews && listing.reviews.length > 0) {
                    hasReviews = true;
                }
            }
        %>
        
        <% if(!hasReviews) { %>
            <div class="alert bg-body-tertiary border shadow-sm text-center py-4 rounded-4">
                <i class="fa-regular fa-comments text-muted fs-1 mb-3"></i>
                <h5 class="text-muted">No reviews received yet.</h5>
            </div>
        <% } else { %>
            <div class="list-group mb-5 shadow-sm rounded-4">
                <% for(let listing of listings) { %>
                    <% if(listing.reviews && listing.reviews.length > 0) { %>
                        <div class="list-group-item bg-body-tertiary text-body fw-bold border-bottom-0 mt-3 first-of-type:mt-0"><i class="fa-solid fa-house me-2 text-primary"></i><%= listing.title %></div>
                        <% for(let review of listing.reviews) { %>
                            <div class="list-group-item py-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-semibold"><i class="fa-solid fa-circle-user me-2 text-secondary fs-5 align-middle"></i><%= review.author.username %></span>
                                    <p class="starability-result m-0" style="transform: scale(0.7); transform-origin: right;" data-rating="<%= review.rating %>"></p>
                                </div>
                                <p class="mb-0 text-muted fst-italic">"<%= review.comment %>"</p>
                            </div>
                        <% } %>
                    <% } %>
                <% } %>
            </div>
        <% } %>
    </div>
    </div>
</div>

<!-- Edit Email Modal -->
<div class="modal fade" id="editEmailModal" tabindex="-1" aria-labelledby="editEmailModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-4 border-0 shadow-lg">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="editEmailModalLabel"><i class="fa-solid fa-envelope me-2 text-primary"></i>Update Email Address</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <form action="/profile/edit-email" method="POST">
            <div class="mb-4">
                <label for="newEmail" class="form-label fw-semibold">New Email Address</label>
                <input type="email" class="form-control" id="newEmail" name="email" value="<%= currUser.email %>" required>
            </div>
            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-primary rounded-pill px-4">Save Changes</button>
            </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Welcome Guide Modal -->
<div class="modal fade" id="welcomeGuideModal" tabindex="-1" aria-labelledby="welcomeGuideModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content rounded-4 border-0 shadow-lg">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="welcomeGuideModalLabel"><i class="fa-solid fa-envelope-open-text text-primary me-2"></i>Your Personalized Welcome Guide</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4" id="welcomeGuideContent">
        <!-- Content will be injected here -->
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- Host Analytics Dashboard ---
    const hostAnalyticsBtn = document.getElementById('hostAnalyticsBtn');
    if (hostAnalyticsBtn) {
        hostAnalyticsBtn.addEventListener('click', async () => {
            const container = document.getElementById('hostAnalyticsContainer');
            const content = document.getElementById('hostAnalyticsContent');

            hostAnalyticsBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Analyzing Reviews...';
            hostAnalyticsBtn.disabled = true;

            try {
                const response = await fetch('/profile/host-analytics');
                const data = await response.json();

                if (data.success) {
                    content.innerHTML = data.analytics;
                    container.classList.remove('d-none');
                } else {
                    alert(data.error || 'Failed to generate insights.');
                }
            } catch (error) {
                console.error(error);
                alert('Error contacting AI service.');
            } finally {
                hostAnalyticsBtn.innerHTML = '<i class="fa-solid fa-chart-line me-2"></i> Refresh Insights';
                hostAnalyticsBtn.disabled = false;
            }
        });
    }

    // --- Welcome Guide Modals ---
    const welcomeGuideBtns = document.querySelectorAll('.welcome-guide-btn');
    const welcomeGuideModalEl = document.getElementById('welcomeGuideModal');
    let welcomeGuideModal;
    
    if (welcomeGuideModalEl) {
        welcomeGuideModal = new bootstrap.Modal(welcomeGuideModalEl);
    }
    
    const welcomeGuideContent = document.getElementById('welcomeGuideContent');

    welcomeGuideBtns.forEach(btn => {
        btn.addEventListener('click', async () => {
            const bookingId = btn.getAttribute('data-booking-id');
            const listingId = btn.getAttribute('data-listing-id');
            const originalHtml = btn.innerHTML;
            
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-1"></i> Loading...';
            btn.disabled = true;

            try {
                const response = await fetch(`/listings/${listingId}/book/${bookingId}/welcome-guide`);
                const data = await response.json();

                if (data.success) {
                    welcomeGuideContent.innerHTML = data.guide;
                    welcomeGuideModal.show();
                } else {
                    alert(data.error || 'Failed to fetch welcome guide.');
                }
            } catch (error) {
                console.error(error);
                alert('Error contacting AI service.');
            } finally {
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        });
    });
});
</script>
